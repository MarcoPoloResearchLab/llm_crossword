CROSSWORDAPI_LISTEN_ADDR=:9090
CROSSWORDAPI_LEDGER_ADDR=ledger:50051
CROSSWORDAPI_LEDGER_INSECURE=true
CROSSWORDAPI_LEDGER_TIMEOUT=3s
CROSSWORDAPI_DEFAULT_TENANT_ID=default
CROSSWORDAPI_DEFAULT_LEDGER_ID=default
CROSSWORDAPI_ALLOWED_ORIGINS=http://localhost:8000
CROSSWORDAPI_JWT_SIGNING_KEY=<base64-encoded-key-must-match-tauth>
CROSSWORDAPI_JWT_ISSUER=tauth
CROSSWORDAPI_JWT_COOKIE_NAME=app_session
CROSSWORDAPI_TAUTH_BASE_URL=http://tauth:8080
CROSSWORDAPI_LLM_PROXY_URL=https://llm-proxy.mprlab.com
CROSSWORDAPI_LLM_PROXY_KEY=<llm-proxy-service-secret>
CROSSWORDAPI_LLM_PROXY_TIMEOUT=30s

# Billing (Paddle credit packs)
CROSSWORDAPI_BILLING_PROVIDER=paddle
CROSSWORDAPI_PADDLE_ENVIRONMENT=sandbox
CROSSWORDAPI_PADDLE_API_KEY=<paddle-api-key>
CROSSWORDAPI_PADDLE_CLIENT_TOKEN=<paddle-client-token>
CROSSWORDAPI_PADDLE_WEBHOOK_SECRET=<paddle-webhook-secret>
CROSSWORDAPI_PADDLE_PRICE_ID_PACK_STARTER=<paddle-price-id>
CROSSWORDAPI_PADDLE_PRICE_ID_PACK_CREATOR=<paddle-price-id>
CROSSWORDAPI_PADDLE_PRICE_ID_PACK_PUBLISHER=<paddle-price-id>
